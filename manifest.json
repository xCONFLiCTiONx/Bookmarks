{
  "manifest_version": 3,
  "name": "Bookmarks",
  "version": "1.0",
  "description": "A clean, dark-themed bookmark navigation menu with alphabetical sort.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "bookmarks",
    "downloads"
  ]
}